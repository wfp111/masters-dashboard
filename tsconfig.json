{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*.ts",
    "data/**/*.ts",
    "lib/**/*.ts",
    "providers/**/*.ts",
    "netlify/functions/**/*.ts",
    "server.ts"
  ]
}
